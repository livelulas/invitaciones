<section class="invitation-section <%= css_class %> invitation-location invitation-location--screen" style="<%= section_style_attr %>">
  <div class="invitation-location__layout">
    <div class="invitation-location__polaroids">
      <% Array(assets&.travel_polaroids).each_with_index do |image, index| %>
        <img
          class="invitation-location__polaroid invitation-location__polaroid--<%= index + 1 %>"
          src="<%= asset_url(image) %>"
          alt="Elena y Armando"
          loading="lazy"
        >
      <% end %>
    </div>

    <div class="invitation-location__copy">
      <h2 class="invitation-location__title"><%= content_data&.title || "Hotel Sede" %></h2>
      <% if content_data&.message %>
        <p class="invitation-location__message"><%= content_data.message %></p>
      <% end %>
      <div class="invitation-location__actions">
        <% if content_data&.details_url && !content_data.details_url.to_s.empty? %>
          <a
            class="invitation-button invitation-button--light"
            href="<%= content_data.details_url %>"
            <% if content_data&.details_target %>
              target="<%= content_data.details_target %>"
              rel="noopener"
            <% end %>
          >
            <%= content_data.details_label || "Detalles" %>
          </a>
        <% else %>
          <span class="invitation-button invitation-button--light invitation-button--ghost"><%= content_data&.details_label || "Detalles" %></span>
        <% end %>

        <% if content_data&.map_url && !content_data.map_url.to_s.empty? %>
          <a class="invitation-button invitation-button--light" href="<%= content_data.map_url %>" target="_blank" rel="noopener">
            <%= content_data.map_label || "Ver ubicación" %>
          </a>
        <% else %>
          <span class="invitation-button invitation-button--light invitation-button--ghost"><%= content_data&.map_label || "Ver ubicación" %></span>
        <% end %>
      </div>
    </div>
  </div>
</section>
