<section class="invitation-section <%= css_class %> invitation-details invitation-details--screen" style="<%= section_style_attr %>" id="details">
  <% transfer = content_data&.transfer || invitation.content&.gift&.transfer %>

  <div class="invitation-details__layout">
    <div class="invitation-details__left-panel">
      <% if asset_url(assets&.parents_photo) %>
        <img
          src="<%= asset_url(assets.parents_photo) %>"
          alt=""
          class="invitation-details__photo"
          role="presentation"
        >
      <% end %>

      <div class="invitation-details__note">
        <div class="invitation-parents__card invitation-details__card">
          <% if asset_url(assets&.parents_clip) %>
            <img
              src="<%= asset_url(assets.parents_clip) %>"
              alt=""
              class="invitation-parents__clip"
              role="presentation"
            >
          <% end %>

          <div class="invitation-details__card-content">
            <h2 class="invitation-details__heading"><%= content_data&.title || label_for(:details_title, "Detalles") %></h2>

            <% if content_data&.children == false %>
              <p class="invitation-details__children"><%= content_data&.children_note || label_for(:children_note, "Respetuosamente No niños") %></p>
            <% end %>

            <div class="invitation-details__dress-intro">
              <h3 class="invitation-details__subheading">Dress Code</h3>

              <% if content_data&.dress_code_intro %>
                <p class="invitation-details__text"><%= content_data.dress_code_intro %></p>
              <% end %>
            </div>

            <% if content_data&.dress_code_women || content_data&.dress_code_men %>
              <div class="invitation-details__dress-codes">
                <% if content_data&.dress_code_women %>
                  <p class="invitation-details__dress-code"><strong><%= content_data.dress_code_women %></strong></p>
                <% end %>
                <% if content_data&.dress_code_men %>
                  <p class="invitation-details__dress-code"><strong><%= content_data.dress_code_men %></strong></p>
                <% end %>
              </div>
            <% end %>

            <% if content_data&.dress_code_note %>
              <p class="invitation-details__dress-note"><%= content_data.dress_code_note %></p>
            <% end %>

            <% if content_data&.gift_message %>
              <p class="invitation-details__gift-message"><%= content_data.gift_message %></p>
            <% end %>

            <% if transfer %>
              <div class="invitation-details__transfer">
                <% if asset_url(assets&.details_transfer_icon) %>
                  <div class="invitation-details__transfer-icon">
                    <img
                      src="<%= asset_url(assets.details_transfer_icon) %>"
                      alt=""
                      class="invitation-details__transfer-graphic"
                      role="presentation"
                    >
                  </div>
                <% end %>
                <div class="invitation-details__transfer-copy">
                  <p class="invitation-details__transfer-label"><%= content_data&.transfer_label || label_for(:transfer_label, "Transferencias") %></p>
                  <p class="invitation-details__transfer-name"><strong><%= transfer.name %></strong></p>
                  <p class="invitation-details__transfer-account"><%= transfer.account %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div
      class="invitation-details__right-panel"
      <% if asset_url(assets&.story_bg) %>
        style="background-image: url('<%= asset_url(assets.story_bg) %>')"
      <% end %>
    >
      <% if asset_url(assets&.details_bee) %>
        <img
          src="<%= asset_url(assets.details_bee) %>"
          alt=""
          class="invitation-details__bee"
          role="presentation"
        >
      <% end %>

      <% if content_data&.closing_title %>
        <h2 class="invitation-details__closing"><%= content_data.closing_title %></h2>
      <% end %>

      <%= render Invitation::GuestName.new(
        invitation: invitation,
        label: content_data&.guest_label,
        default: content_data&.guest_default
      ) %>

      <p class="invitation-details__rsvp">
        <%= content_data&.rsvp_message %>
        <strong><%= formatted_rsvp_deadline %></strong>
      </p>
    </div>
  </div>
</section>
