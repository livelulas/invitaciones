<!doctype html>
<html lang="es">
  <head>
    <%= render "head_home", metadata: site.metadata, title: data.title %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Montserrat:wght@400;500;600&display=swap">
  </head>
  <body class="home">
    <%= render Shared::Navbar.new(metadata: site.metadata, resource: resource) %>

    <main class="home-main">
      <%= render Shared::HomePage.new(site: site, metadata: site.metadata) %>
    </main>

    <%= render "footer", metadata: site.metadata %>
  </body>
</html>
