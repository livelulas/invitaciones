<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<% resource_title = strip_html(strip_newlines(title)) %>
<title><% if resource_title != "Index" %><%= resource_title %> | <%= metadata.title %><% else %><%= metadata.title %>: <%= metadata.tagline %><% end %></title>

<meta name="description" content="<%= metadata.description %>" />

<link rel="icon" href="<%= relative_url '/images/logo.png' %>" type="image/png" />
<link rel="apple-touch-icon" href="<%= relative_url '/images/logo.png' %>" />
<link rel="stylesheet" href="<%= asset_path 'styles/home-index.css' %>" />
<%= live_reload_dev_js %>
